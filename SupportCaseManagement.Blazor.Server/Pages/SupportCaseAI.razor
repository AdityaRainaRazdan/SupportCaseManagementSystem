@* @using SupportCaseManagement.Module.BusinessObjects
@using SupportCaseManagement.Module.AI
@using SupportCaseManagement.Blazor.Server.Services
@using SupportCaseManagement.Module.Services

@inject AIService AIService

<div style="border:1px solid #ccc;padding:10px;margin-top:20px">

    <h4>🤖 AI Assistant</h4>

<textarea @bind="UserMessage"
          style="width:100%;height:80px"
          placeholder="Ask AI about this case">
</textarea>

    <br />

    <button class="btn btn-primary" @onclick="AskAI">
        Ask AI
    </button>

    @if (!string.IsNullOrEmpty(AIResponseText))
    {
        <div style="margin-top:10px">

            <b>AI Response</b>

            <p>@AIResponseText</p>

        </div>
    }

    @if (ProposedActions.Count > 0)
    {

        <h5>Proposed Actions</h5>

        @foreach (var action in ProposedActions)
        {

            <div style="border:1px solid #ddd;padding:5px;margin-bottom:5px">

                <p>@action.Description</p>

                <button class="btn btn-success"
                        @onclick="() => ConfirmAction(action)">
                    Apply
                </button>

            </div>

        }
    }

</div>

@code {

    [Parameter]
    public SupportCase Case { get; set; }

    string UserMessage;

    string AIResponseText;

    List<AIAction> ProposedActions = new();

    async Task AskAI()
    {
        var response = await AIService.AnalyzeCase(Case, UserMessage);

        AIResponseText = response.Message;

        ProposedActions = response.Actions;
    }

    async Task ConfirmAction(AIAction action)
    {
        await AIService.ExecuteAction(Case, action);

        ProposedActions.Remove(action);
    }

} *@
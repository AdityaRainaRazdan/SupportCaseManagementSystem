@using SupportCaseManagement.Module.BusinessObjects
@inject HttpClient Http

<div style="border:1px solid #ddd;padding:10px;border-radius:8px;height:400px;overflow:auto">

    <h4>🤖 Support AI Assistant</h4>

    <div style="height:260px;overflow:auto">
        @foreach (var m in Messages)
        {
            <div style="margin-bottom:8px">
                <b>@m.Role:</b> @m.Text
            </div>
        }
    </div>

<textarea @bind="UserInput" style="width:100%;height:60px"></textarea>

    <br />

    <button class="btn btn-primary" @onclick="SendMessage">
        Send
    </button>

    @if (Plan != null)
    {
        <hr />

        <h5>⚡ Proposed Action</h5>

        <div>@Plan.Description</div>

        <button class="btn btn-success" @onclick="ApplyPlan">
            Apply Plan
        </button>
    }

</div>

@code {

    [Parameter]
    public SupportCase Case { get; set; }

    string UserInput;

    List<Message> Messages = new();

    AIPlan Plan;

    async Task SendMessage()
    {
        Messages.Add(new Message
        {
            Role = "User",
            Text = UserInput
        });

        var request = new
        {
            message = UserInput,
            title = Case.Title,
            description = Case.Description,
            priority = Case.Priority.ToString(),
            status = Case.Status.ToString()
        };

        var res = await Http.PostAsJsonAsync("http://127.0.0.1:8000/agent-chat", request);

        var ai = await res.Content.ReadFromJsonAsync<AIResponse>();

        Messages.Add(new Message
        {
            Role = "AI",
            Text = ai.reply
        });

        Plan = ai.plan;

        UserInput = "";
    }

    void ApplyPlan()
    {
        if (Plan == null)
            return;

        if (Plan.set_priority != null)
            Case.Priority = Enum.Parse<CasePriority>(Plan.set_priority);

        if (Plan.set_status != null)
            Case.Status = Enum.Parse<CaseStatus>(Plan.set_status);
    }

    class Message
    {
        public string Role { get; set; }
        public string Text { get; set; }
    }

    class AIResponse
    {
        public string reply { get; set; }
        public AIPlan plan { get; set; }
    }

    class AIPlan
    {
        public string Description { get; set; }

        public string set_priority { get; set; }

        public string set_status { get; set; }
    }

}
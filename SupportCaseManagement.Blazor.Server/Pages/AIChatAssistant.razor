@* SupportCaseManagement.Blazor.Server/Pages/AIChatAssistant.razor *@
@using Microsoft.JSInterop
@using SupportCaseManagement.Module.BusinessObjects
@using SupportCaseManagement.Module.AIBackend
@using SupportCaseManagement.Module.DTO
@using SupportCaseManagement.Module.Services
@using Microsoft.AspNetCore.Components.Web
@using DevExpress.ExpressApp
@inject IObjectSpaceFactory ObjectSpaceFactory
@inject AgenticAIService AiService
@inject IJSRuntime JS

<style>
    :root{--bg:#0f1117;--surface:#1a1d27;--surface2:#22263a;--border:#2e3248;--accent:#4f8ef7;--accent2:#7c3aed;--user-bubble:#1d4ed8;--ai-bubble:#1e2235;--plan-bg:#0d2218;--plan-border:#166534;--text:#e8eaf6;--text-dim:#6b7280;--text-muted:#9ca3af;--success:#22c55e;--warn:#d97706;--radius:18px;--rsm:10px;--font:'Segoe UI',system-ui,sans-serif;}
    .root{font-family:var(--font);background:var(--bg);color:var(--text);height:calc(100vh - 120px);display:flex;flex-direction:column;overflow:hidden;border-radius:8px;}
    .hdr{background:var(--surface);border-bottom:1px solid var(--border);padding:14px 20px;display:flex;align-items:center;gap:14px;flex-shrink:0;border-radius:8px 8px 0 0;}
    .av{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-size:20px;}
    .hi h3{margin:0;font-size:15px;font-weight:600;display:flex;align-items:center;gap:8px;}
    .mbadge{font-size:11px;padding:2px 8px;border-radius:20px;background:var(--surface2);color:var(--text-muted);border:1px solid var(--border);font-weight:400;}
    .mbadge.on{background:#1e3a5f;color:#93c5fd;border-color:#2563eb;}
    .hst{font-size:12px;color:var(--success);}.hst.idle{color:var(--text-dim);}
    .cbar{background:var(--surface2);border-bottom:1px solid var(--border);padding:10px 20px;display:flex;align-items:center;gap:10px;flex-shrink:0;flex-wrap:wrap;}
    .cbar label{font-size:12px;color:var(--text-muted);white-space:nowrap;font-weight:500;text-transform:uppercase;letter-spacing:.05em;}
    .csel{flex:1;min-width:200px;background:var(--surface);border:1px solid var(--border);color:var(--text);padding:7px 12px;border-radius:var(--rsm);font-size:13px;outline:none;cursor:pointer;}
    .csel:focus{border-color:var(--accent);}
    .btn-an{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;border:none;padding:7px 16px;border-radius:var(--rsm);font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap;}
    .btn-an:disabled,.btn-qa:disabled{opacity:.4;cursor:not-allowed;}
    .btn-sec{background:transparent;color:var(--text-muted);border:1px solid var(--border);padding:7px 12px;border-radius:var(--rsm);font-size:12px;cursor:pointer;}
    .btn-sec:hover{border-color:var(--accent);color:var(--text);}
    .qbar{background:var(--surface);border-bottom:1px solid var(--border);padding:8px 20px;display:flex;gap:8px;flex-shrink:0;overflow-x:auto;}
    .qbar::-webkit-scrollbar{height:3px;}
    .btn-qa{background:var(--surface2);border:1px solid var(--border);color:var(--text-muted);padding:5px 12px;border-radius:20px;font-size:12px;cursor:pointer;white-space:nowrap;}
    .btn-qa:hover{border-color:var(--accent);color:var(--text);}
    .win{flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:10px;}
    .win::-webkit-scrollbar{width:4px;}
    .win::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}
    .row{display:flex;align-items:flex-end;gap:8px;}
    .row.u{justify-content:flex-end;}.row.a{justify-content:flex-start;}
    .ico{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
    .bub{max-width:72%;padding:10px 14px;border-radius:var(--radius);font-size:13.5px;line-height:1.6;word-break:break-word;white-space:pre-wrap;}
    .bub.u{background:var(--user-bubble);color:white;border-bottom-right-radius:4px;}
    .bub.a{background:var(--ai-bubble);color:var(--text);border-bottom-left-radius:4px;border:1px solid var(--border);}
    .bub.sys{background:var(--surface2);color:var(--text-muted);border-radius:var(--rsm);max-width:100%;text-align:center;align-self:center;padding:5px 14px;font-size:12px;}
    .btime{font-size:10px;color:var(--text-dim);margin-top:4px;}
    /* Plan card */
    .pcard{max-width:84%;background:var(--plan-bg);border:1px solid var(--plan-border);border-radius:var(--radius);border-bottom-left-radius:4px;padding:16px;}
    .phead{display:flex;align-items:center;gap:8px;margin-bottom:14px;}
    .phead h4{margin:0;font-size:14px;color:var(--success);font-weight:700;}
    .stitle{font-size:11px;text-transform:uppercase;color:var(--text-muted);letter-spacing:.06em;margin-bottom:6px;font-weight:600;}
    .psec{margin-bottom:12px;}
    .prow{display:flex;gap:8px;margin-bottom:5px;align-items:center;}
    .plbl{font-size:11px;color:var(--text-muted);min-width:80px;text-transform:uppercase;}
    .pval{font-size:13px;color:var(--text);font-weight:500;}
    .badge{display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;}
    .bp1{background:#7f1d1d;color:#fca5a5;}.bp2{background:#78350f;color:#fcd34d;}.bp3{background:#1e3a5f;color:#93c5fd;}
    .bst{background:#1e3a5f;color:#93c5fd;}.btm{background:#4c1d95;color:#c4b5fd;}
    .steps{list-style:none;padding:0;margin:0;}
    .steps li{padding:4px 0 4px 20px;position:relative;font-size:13px;line-height:1.5;}
    .steps li::before{content:"→";position:absolute;left:0;color:var(--accent);}
    .kblist{display:flex;flex-direction:column;gap:6px;}
    .kbitem{display:flex;align-items:center;justify-content:space-between;background:rgba(0,0,0,.2);padding:7px 10px;border-radius:var(--rsm);gap:8px;}
    .kbi{display:flex;flex-direction:column;}
    .kbt{font-size:13px;color:var(--text);}.kbc{font-size:11px;color:var(--text-muted);}
    .btn-link{background:#1e3a5f;color:#93c5fd;border:1px solid #2563eb;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;cursor:pointer;white-space:nowrap;}
    .btn-link:disabled{opacity:.4;cursor:not-allowed;}
    .draftbox{background:rgba(0,0,0,.2);border-left:3px solid var(--accent);padding:8px 12px;border-radius:0 var(--rsm) var(--rsm) 0;font-size:12px;color:var(--text-muted);font-style:italic;line-height:1.6;}
    .rbox{font-size:12px;color:var(--text-muted);line-height:1.6;}
    .pbtns{display:flex;gap:8px;margin-top:14px;}
    .btn-apply{flex:1;background:var(--success);color:white;border:none;padding:9px;border-radius:var(--rsm);font-size:13px;font-weight:700;cursor:pointer;}
    .btn-apply:disabled{opacity:.4;cursor:not-allowed;}
    .btn-dis{background:transparent;color:var(--text-muted);border:1px solid var(--border);padding:9px 16px;border-radius:var(--rsm);font-size:13px;cursor:pointer;}
    .btn-dis:hover{border-color:#ef4444;color:#ef4444;}
    /* Inline action confirmation */
    .acard{max-width:72%;background:var(--plan-bg);border:1px solid var(--plan-border);border-radius:var(--radius);border-bottom-left-radius:4px;padding:12px 14px;}
    .atitle{color:var(--success);font-weight:600;margin-bottom:8px;font-size:13px;}
    .adetail{color:var(--text-muted);font-size:12px;margin-bottom:10px;line-height:1.7;}
    .adetail strong{color:var(--text);}
    .abtns{display:flex;gap:8px;}
    .btn-ok{background:var(--success);color:white;border:none;padding:6px 16px;border-radius:var(--rsm);font-size:12px;font-weight:700;cursor:pointer;}
    .btn-no{background:transparent;color:var(--text-muted);border:1px solid var(--border);padding:6px 12px;border-radius:var(--rsm);font-size:12px;cursor:pointer;}
    .btn-no:hover{border-color:#ef4444;color:#ef4444;}
    /* Typing */
    .typing{display:flex;align-items:center;gap:8px;padding:6px 0;}
    .tdots{display:flex;gap:4px;background:var(--ai-bubble);border:1px solid var(--border);padding:10px 14px;border-radius:var(--radius);border-bottom-left-radius:4px;}
    .tdots span{width:7px;height:7px;background:var(--text-muted);border-radius:50%;animation:tdB 1.2s infinite;}
    .tdots span:nth-child(2){animation-delay:.2s;}.tdots span:nth-child(3){animation-delay:.4s;}
    /* Empty */
    .empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;color:var(--text-dim);text-align:center;padding:40px;}
    .empty .ico2{font-size:52px;opacity:.35;}
    .empty p{margin:0;font-size:15px;font-weight:500;color:var(--text-muted);}
    .empty small{font-size:12px;opacity:.6;max-width:320px;line-height:1.6;}
    .sug{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:4px;}
    .sbtn{background:var(--surface2);border:1px solid var(--border);color:var(--text-muted);padding:6px 14px;border-radius:20px;font-size:12px;cursor:pointer;}
    .sbtn:hover{border-color:var(--accent);color:var(--text);}
    /* Input */
    .ibar{background:var(--surface);border-top:1px solid var(--border);padding:12px 16px;display:flex;align-items:flex-end;gap:10px;flex-shrink:0;border-radius:0 0 8px 8px;}
    .ta{flex:1;background:var(--surface2);border:1px solid var(--border);color:var(--text);padding:10px 14px;border-radius:22px;font-size:13.5px;font-family:var(--font);resize:none;outline:none;min-height:42px;max-height:120px;overflow-y:auto;line-height:1.5;}
    .ta:focus{border-color:var(--accent);}
    .ta::placeholder{color:var(--text-dim);}
    .btn-send{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));border:none;color:white;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .btn-send:disabled{opacity:.35;cursor:not-allowed;}
    .err{background:#7f1d1d;color:#fca5a5;padding:8px 14px;font-size:12px;text-align:center;border-radius:var(--rsm);margin:0 20px 8px;}
</style>
<script>
    (function(){if(document.getElementById('aicss'))return;var s=document.createElement('style');s.id='aicss';s.textContent='@@keyframes tdB{0%,80%,100%{transform:translateY(0);opacity:.4}40%{transform:translateY(-5px);opacity:1}}';document.head.appendChild(s);})();
</script>

<div class="root">
    <!-- Header -->
    <div class="hdr">
        <div class="av">🤖</div>
        <div class="hi">
            <h3>AI Support Assistant
                <span class="mbadge @(Case!=null?"on":"")">@(Case!=null?$"📁 {Case.CaseNumber}":"General Chat")</span>
            </h3>
            <span class="hst @(Busy?"":"idle")">@(Busy?"typing...":"online")</span>
        </div>
    </div>

    <!-- Case selector -->
    <div class="cbar">
        <label>📁 Case</label>
        <select class="csel" @onchange="OnCaseSelected" disabled="@Busy">
            <option value="">— General chat —</option>
            @foreach (var c in Cases)
            {
                <option value="@c.ID">@c.CaseNumber — @c.Title (@c.Status / @c.Priority)</option>
            }
        </select>
        <button class="btn-an" @onclick="Analyze" disabled="@(Case==null||Busy)">🔍 Analyze</button>
        <button class="btn-sec" @onclick="Clear">Clear</button>
    </div>

    <!-- Quick actions (case mode only) -->
    @if (Case != null)
    {
        <div class="qbar">
            <button class="btn-qa" disabled="@Busy" @onclick='()=>Q("Summarize this case including all its comments")'>📋 Summarize</button>
            <button class="btn-qa" disabled="@Busy" @onclick='()=>Q("What are the next steps I should take on this case?")'>👣 Next Steps</button>
            <button class="btn-qa" disabled="@Busy" @onclick='()=>Q("What priority, status, and team should this case be assigned to?")'>🎯 Priority &amp; Team</button>
            <button class="btn-qa" disabled="@Busy" @onclick='()=>Q("Search the knowledge base for articles relevant to this case and suggest which ones to link")'>📚 Find KB Articles</button>
            <button class="btn-qa" disabled="@Busy" @onclick='()=>Q("Draft a professional response message I can send to the customer")'>✉️ Draft Reply</button>
        </div>
    }

    <!-- Messages -->
    <div class="win" id="chatWin">
        @if (!Msgs.Any())
        {
            <div class="empty">
                <div class="ico2">🤖</div>
                <p>Hi! I'm your AI Support Assistant</p>
                <small>Select a case to analyze it, or ask me anything.
                    @if (Cases.Any()) { <span>I can see <strong>@Cases.Count cases</strong> in your system.</span> }
                </small>
                <div class="sug">
                    <button class="sbtn" @onclick='()=>Q("Show me a summary of all open cases")'>Show open cases</button>
                    <button class="sbtn" @onclick='()=>Q("Which cases are high priority or overdue?")'>Which are urgent?</button>
                    <button class="sbtn" @onclick='()=>Q("What makes a good P1 case?")'>What is a P1?</button>
                    <button class="sbtn" @onclick='()=>Q("How should I triage a new support case?")'>How to triage?</button>
                </div>
            </div>
        }
        @foreach (var m in Msgs)
        {
            @if (m.IsSys)
            {
                <div class="bub sys">@m.Text</div>
            }
            else if (m.IsPlan && m.Plan != null)
            {
                <div class="row a"><div class="ico">🤖</div>
                <div>
                    <div class="pcard">
                        <div class="phead"><span>📊</span><h4>AI Analysis &amp; Action Proposal</h4></div>

                        <div class="psec"><div class="stitle">Summary</div>
                            <div style="font-size:13.5px;line-height:1.6">@m.Plan.Summary</div></div>

                        @if (m.Plan.NextSteps?.Any()==true)
                        {
                            <div class="psec"><div class="stitle">Suggested Next Steps</div>
                                <ul class="steps">@foreach(var s in m.Plan.NextSteps){<li>@s</li>}</ul></div>
                        }

                        <div class="psec"><div class="stitle">Proposed Changes</div>
                            <div class="prow"><span class="plbl">Priority</span>
                                <span class="badge @PBadge(m.Plan.SuggestedPriority)">@(m.Plan.SuggestedPriority??"No change")</span></div>
                            <div class="prow"><span class="plbl">Status</span>
                                <span class="badge bst">@(m.Plan.SuggestedStatus??"No change")</span></div>
                            <div class="prow"><span class="plbl">Team</span>
                                @if (!string.IsNullOrEmpty(m.Plan.MatchedTeamName))
                                { <span class="badge btm">@m.Plan.MatchedTeamName</span> }
                                else if (!string.IsNullOrEmpty(m.Plan.AssignTeam))
                                { <span class="pval" style="color:var(--warn)">@m.Plan.AssignTeam (not found in DB)</span> }
                                else { <span class="pval">No change</span> }
                            </div>
                        </div>

                        @if (m.Plan.MatchedKBArticles?.Any()==true)
                        {
                            <div class="psec"><div class="stitle">Recommended KB Articles</div>
                                <div class="kblist">
                                @foreach (var kb in m.Plan.MatchedKBArticles)
                                {
                                    <div class="kbitem">
                                        <div class="kbi"><span class="kbt">@kb.Title</span>
                                            @if(!string.IsNullOrEmpty(kb.Category)){<span class="kbc">@kb.Category</span>}</div>
                                        <button class="btn-link" @onclick="()=>LinkKB(kb,m.CaseId,m)"
                                                disabled="@m.Linked.Contains(kb.Id)">
                                            @(m.Linked.Contains(kb.Id)?"✅ Linked":"🔗 Link")</button>
                                    </div>
                                }
                                </div></div>
                        }
                        else if (m.Plan.SuggestedKBArticle?.Any()==true)
                        {
                            <div class="psec"><div class="stitle">KB Articles Suggested</div>
                                @foreach(var t in m.Plan.SuggestedKBArticle){<div style="font-size:12px;padding:2px 0;color:var(--text-muted)">📄 @t</div>}
                                <small style="color:var(--text-muted);font-size:11px">Not found in your KB — consider creating these articles.</small></div>
                        }

                        @if (!string.IsNullOrEmpty(m.Plan.ProposedCustomerMessage))
                        {
                            <div class="psec"><div class="stitle">Proposed Customer Message</div>
                                <div class="draftbox">@m.Plan.ProposedCustomerMessage</div></div>
                        }

                        <div class="psec"><div class="stitle">Reasoning</div>
                            <div class="rbox">@m.Plan.Reasoning</div></div>

                        @if (!m.Applied && !m.Rejected)
                        {
                            <div style="font-size:12px;color:var(--warn);margin-bottom:8px">⚠️ Review proposed changes before applying.</div>
                            <div class="pbtns">
                                <button class="btn-apply" @onclick="()=>ApplyPlan(m)">⚡ Apply These Changes</button>
                                <button class="btn-dis"   @onclick="()=>RejectPlan(m)">✗ Dismiss</button>
                            </div>
                        }
                        else if (m.Applied) { <div style="color:var(--success);font-weight:600;margin-top:8px">✅ Changes applied to case</div> }
                        else                { <div style="color:var(--text-muted);margin-top:8px">✗ Dismissed — no changes made</div> }
                    </div>
                    <div class="btime">@m.At.ToString("HH:mm")</div>
                </div></div>
            }
            else if (m.IsAction && m.Act != null)
            {
                <div class="row a"><div class="ico">🤖</div>
                <div>
                    @if (!m.ActDone && !m.ActNo)
                    {
                        <div class="acard">
                            <div class="atitle">🔔 Proposed Action — please confirm</div>
                            <div class="adetail">
                                @if (!string.IsNullOrEmpty(m.Act.Priority))
                                { <div>Priority → <strong>@m.Act.Priority</strong></div> }
                                @if (!string.IsNullOrEmpty(m.Act.Status))
                                { <div>Status → <strong>@m.Act.Status</strong></div> }
                                @if (!string.IsNullOrEmpty(m.Act.TeamName))
                                { <div>Assign Team → <strong>@m.Act.TeamName</strong></div> }
                                else if (!string.IsNullOrEmpty(m.Act.AssignTeam))
                                { <div style="color:var(--warn)">Team "@m.Act.AssignTeam" not matched in DB</div> }
                                @if (m.Act.KbMatch != null)
                                { <div>Link KB → <strong>@m.Act.KbMatch.Title</strong></div> }
                                else if (!string.IsNullOrEmpty(m.Act.KbArticleTitle))
                                { <div style="color:var(--warn)">KB "@m.Act.KbArticleTitle" not found in DB</div> }
                            </div>
                            <div class="abtns">
                                <button class="btn-ok" @onclick="()=>ExecAction(m)">✅ Confirm</button>
                                <button class="btn-no" @onclick="()=>DenyAction(m)">✗ Cancel</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="bub a">@(m.ActDone ? m.ActResult : "Cancelled — no changes made.")</div>
                    }
                    <div class="btime">@m.At.ToString("HH:mm")</div>
                </div></div>
            }
            else
            {
                <div class="row @(m.IsAI?"a":"u")">
                    @if(m.IsAI){<div class="ico">🤖</div>}
                    <div>
                        <div class="bub @(m.IsAI?"a":"u")">@m.Text</div>
                        <div class="btime">@m.At.ToString("HH:mm")</div>
                    </div>
                </div>
            }
        }
        @if (Busy)
        {
            <div class="typing"><div class="ico">🤖</div>
                <div class="tdots"><span></span><span></span><span></span></div></div>
        }
    </div>

    @if (!string.IsNullOrEmpty(Err))
    {
        <div class="err">⚠️ @Err</div>
    }

    <div class="ibar">
        <textarea class="ta" @bind="Input" @bind:event="oninput" @onkeydown="OnKey"
                  placeholder="@(Case!=null?$"Ask about {Case.CaseNumber}, or say yes to confirm a proposal...":"Ask me anything about your cases...")"
                  disabled="@Busy" rows="1"></textarea>
        <button class="btn-send" @onclick="Send" disabled="@(string.IsNullOrWhiteSpace(Input)||Busy)">&#10148;</button>
    </div>
</div>

@code {
    // ── State ─────────────────────────────────────────────────────────────────
    private List<SupportCase> Cases = new();
    private SupportCase? Case;
    private string Input = "";
    private bool Busy;
    private string Err = "";
    private List<Msg> Msgs = new();
    private List<ConversationMessage> History = new();

    protected override void OnInitialized() => LoadCases();

    // ── Object space ──────────────────────────────────────────────────────────
    private IObjectSpace OS(Type t) => ObjectSpaceFactory.CreateObjectSpace(t);

    // ── Load all SupportCase rows for dropdown ────────────────────────────────
    private void LoadCases()
    {
        try
        {
            using var os = OS(typeof(SupportCase));
            // Order by CreatedDate DESC — SupportCase.CreatedDate
            Cases = os.GetObjectsQuery<SupportCase>()
                      .OrderByDescending(c => c.CreatedDate)
                      .ToList();
        }
        catch (Exception ex) { Err = "Could not load cases: " + ex.Message; }
    }

    // ── Build case summary for general-chat context ───────────────────────────
    private string CasesContext() =>
        Cases.Any()
            ? "Cases in system:\n" + string.Join("\n", Cases.Select(c =>
                $"- [{c.CaseNumber}] \"{c.Title}\" | {c.Status} | {c.Priority} | Created:{c.CreatedDate:yyyy-MM-dd}"))
            : "No cases in system.";

    // ── Priority badge CSS class ──────────────────────────────────────────────
    private static string PBadge(string? p) => p?.ToUpper() switch { "P1"=>"bp1","P2"=>"bp2",_=>"bp3" };

    // ── Case selected from dropdown ───────────────────────────────────────────
    private void OnCaseSelected(ChangeEventArgs e)
    {
        Err = "";
        var id = e.Value?.ToString();
        if (string.IsNullOrEmpty(id)) { Case = null; SysBubble("Switched to General Chat"); return; }
        if (Guid.TryParse(id, out var g))
        {
            try
            {
                using var os = OS(typeof(SupportCase));
                // Load bare case — nav properties loaded on demand in AgenticAIService.BuildSnapshot
                Case = os.GetObjectsQuery<SupportCase>().FirstOrDefault(c => c.ID == g);
                if (Case != null)
                    SysBubble($"📁 {Case.CaseNumber} — {Case.Title} | {Case.Status} / {Case.Priority}");
            }
            catch (Exception ex) { Err = "Could not load case: " + ex.Message; }
        }
    }

    // ── Send a message ────────────────────────────────────────────────────────
    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(Input)) return;
        var txt = Input.Trim();
        Input = ""; Err = "";
        Msgs.Add(new Msg { Text = txt, At = DateTime.Now });
        Busy = true; await Scroll(); StateHasChanged();
        try
        {
            if (Case != null)
            {
                // Case-aware chat — AgenticAIService.ChatWithCase
                // Opens its own OS internally with .Include() for eager loading
                using var os = OS(typeof(SupportCase));
                var r = await AiService.ChatWithCase(Case, txt, os);
                if (r.Action != null)
                    Msgs.Add(new Msg { IsAI=true, IsAction=true, Act=r.Action, CaseId=Case.ID, At=DateTime.Now });
                else
                    Msgs.Add(new Msg { IsAI=true, Text=r.Reply??"", At=DateTime.Now });
            }
            else
            {
                // Free chat — pass case list as system context
                var ctx = new List<ConversationMessage>
                    { new(){Role="system_context", Content=CasesContext()} };
                ctx.AddRange(History);
                var reply = await AiService.Chat(txt, ctx);
                History.Add(new(){Role="user",    Content=txt});
                History.Add(new(){Role="assistant",Content=reply});
                if (History.Count > 20) History = History.Skip(History.Count-20).ToList();
                Msgs.Add(new Msg { IsAI=true, Text=reply, At=DateTime.Now });
            }
        }
        catch (Exception ex)
        {
            Err = "Chat error: " + ex.Message;
            Msgs.Add(new Msg { IsAI=true, Text="Sorry, I couldn't reach the AI service. Is FastAPI running on port 8000?", At=DateTime.Now });
        }
        finally { Busy=false; StateHasChanged(); await Scroll(); }
    }

    private async Task Q(string text) { Input=text; await Send(); }

    // ── Full Analyze → plan card ──────────────────────────────────────────────
    private async Task Analyze()
    {
        if (Case == null) return;
        Err = "";
        Msgs.Add(new Msg { Text=$"Analyze case {Case.CaseNumber}", At=DateTime.Now });
        Busy=true; await Scroll(); StateHasChanged();
        try
        {
            using var os = OS(typeof(SupportCase));
            var p = await AiService.AnalyzeCase(Case, os);
            Msgs.Add(new Msg { IsAI=true, IsPlan=true, Plan=p, CaseId=Case.ID, At=DateTime.Now });
        }
        catch (Exception ex)
        {
            Err = "Analysis error: " + ex.Message;
            Msgs.Add(new Msg { IsAI=true, Text="Sorry, analysis failed.", At=DateTime.Now });
        }
        finally { Busy=false; StateHasChanged(); await Scroll(); }
    }

    // ── Apply full plan card ──────────────────────────────────────────────────
    // Uses AgenticAIService.ApplyProposalToCase which handles:
    //   SupportCase.Priority (CasePriority enum)
    //   SupportCase.Status   (CaseStatus enum)
    //   SupportCase.AssignedTeam (SupportTeam navigation property)
    //   AIInteractionLog
    private async Task ApplyPlan(Msg m)
    {
        try
        {
            using var os = OS(typeof(SupportCase));
            var changes = AiService.ApplyProposalToCase(m.Plan!, m.CaseId, os);
            m.Applied = true;
            Msgs.Add(new Msg { IsAI=true, Text="✅ Applied — "+string.Join(", ", changes), At=DateTime.Now });
            LoadCases();
            StateHasChanged(); await Scroll();
        }
        catch (Exception ex) { Err = "Could not apply plan: " + ex.Message; }
    }

    private void RejectPlan(Msg m)
    {
        m.Rejected = true;
        Msgs.Add(new Msg { IsAI=true, Text="Understood — no changes were made.", At=DateTime.Now });
        StateHasChanged();
    }

    // ── Execute inline action (chat confirmation) ─────────────────────────────
    // Uses AgenticAIService.ExecuteAction which handles:
    //   SupportCase.Priority, Status, AssignedTeam (SupportTeam)
    //   CaseKnowledgeLink (SupportCaseId + KnowledgeBaseArticleId)
    //   AIInteractionLog
    private async Task ExecAction(Msg m)
    {
        try
        {
            using var os = OS(typeof(SupportCase));
            var changes = AiService.ExecuteAction(m.Act!, m.CaseId, os);
            m.ActDone   = true;
            m.ActResult = changes.Any() ? "✅ Done — "+string.Join(", ", changes) : "✅ No changes needed";
            LoadCases();
            StateHasChanged(); await Scroll();
        }
        catch (Exception ex) { Err = "Could not execute action: " + ex.Message; }
    }

    private void DenyAction(Msg m) { m.ActNo = true; StateHasChanged(); }

    // ── Link KB article from plan card button ─────────────────────────────────
    // Creates CaseKnowledgeLink with SupportCaseId + KnowledgeBaseArticleId
    private async Task LinkKB(KBMatch kb, Guid caseId, Msg m)
    {
        try
        {
            using var os = OS(typeof(CaseKnowledgeLink));
            AiService.LinkKBArticle(kb, caseId, os);
            m.Linked.Add(kb.Id);
            Msgs.Add(new Msg { IsAI=true, Text=$"🔗 Linked \"{kb.Title}\" to this case.", At=DateTime.Now });
            StateHasChanged(); await Scroll();
        }
        catch (Exception ex) { Err = "Could not link KB article: " + ex.Message; }
    }

    private void SysBubble(string t) { Msgs.Add(new Msg { IsSys=true, Text=t, At=DateTime.Now }); StateHasChanged(); }
    private void Clear() { Msgs.Clear(); History.Clear(); Err=""; StateHasChanged(); }
    private async Task OnKey(KeyboardEventArgs e) { if (e.Key=="Enter"&&!e.ShiftKey) await Send(); }
    private async Task Scroll()
    {
        try { await JS.InvokeVoidAsync("eval","var e=document.getElementById('chatWin');if(e)e.scrollTop=e.scrollHeight;"); } catch {}
    }

    // ── Message model ─────────────────────────────────────────────────────────
    private class Msg
    {
        public string Text     { get; set; } = "";
        public bool   IsAI     { get; set; }
        public bool   IsSys    { get; set; }
        // Full plan card (from Analyze)
        public bool   IsPlan   { get; set; }
        public bool   Applied  { get; set; }
        public bool   Rejected { get; set; }
        public AIActionProposal? Plan { get; set; }
        // Inline action confirmation (from chat "yes")
        public bool   IsAction  { get; set; }
        public bool   ActDone   { get; set; }
        public bool   ActNo     { get; set; }
        public string ActResult { get; set; } = "";
        public AIActionToExecute? Act { get; set; }
        // Shared
        public Guid   CaseId { get; set; }
        public HashSet<Guid> Linked { get; set; } = new();  // KB articles linked from this bubble
        public DateTime At { get; set; } = DateTime.Now;
    }
}

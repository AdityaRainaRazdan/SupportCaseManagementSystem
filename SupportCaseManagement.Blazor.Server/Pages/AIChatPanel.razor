@using SupportCaseManagement.Module.BusinessObjects

<div class="chat-window">

    @foreach (var msg in Messages)
    {
        <div class="user-msg">
            <b>👤 User:</b> @msg.UserMessage
        </div>

        <div class="ai-msg">
            <b>🤖 AI:</b> @msg.AIResponse
        </div>
    }

</div>

<style>

    .chat-window{
    height:400px;
    overflow-y:auto;
    padding:10px;
    border:1px solid #ddd;
    }

    .user-msg{
    background:#f3f3f3;
    padding:8px;
    margin:5px;
    border-radius:6px;
    }

    .ai-msg{
    background:#e3f2fd;
    padding:8px;
    margin:5px;
    border-radius:6px;
    }

</style>

@code {

    [Parameter]
    public List<AIInteractionLog> Messages { get; set; }

}